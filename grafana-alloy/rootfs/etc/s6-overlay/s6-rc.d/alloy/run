#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Start Grafana Alloy
# ==============================================================================

declare -a args=()

args+=(run)
args+=(/etc/alloy/config.alloy)
args+=(--server.http.listen-addr=0.0.0.0:12345)
args+=(--storage.path=/data/alloy)
args+=(--disable-reporting)

# Set cluster node name to real hostname
HA_HOSTNAME=$(curl -sSf -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
    http://supervisor/host/info 2>/dev/null | jq -r '.data.hostname // empty') \
    || true
if [ -z "${HA_HOSTNAME}" ]; then
    HA_HOSTNAME=$(bashio::host.hostname 2>/dev/null) || true
fi
HA_HOSTNAME="${HA_HOSTNAME:-homeassistant}"
args+=(--cluster.name="${HA_HOSTNAME}")

# Export API key for basic_auth via sys.env()
if bashio::config.has_value 'gcloud_api_key'; then
    export GCLOUD_API_KEY=$(bashio::config 'gcloud_api_key')
fi

bashio::log.info "Starting Grafana Alloy..."
exec alloy "${args[@]}"
